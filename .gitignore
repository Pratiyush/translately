# Third-party reference sources (read-only mirror, never committed)
_reference/

# Build
build/
target/
.gradle/
node_modules/
dist/
.next/
.vite/
.turbo/

# Local
.env
.env.*
!.env.*.example
*.log
.DS_Store
.idea/
.vscode/settings.json

# Test
coverage/
test-results/
playwright-report/

# Quarkus
quarkus-app/
*.jar
.quarkus/
!gradle/wrapper/gradle-wrapper.jar

# Secrets
*.pem
*.key
secrets/
# Committed DEV/TEST JWT keypair (explicitly non-secret; see jwt-dev/README.md)
!backend/app/src/main/resources/jwt-dev/*.pem

# Per-user Claude harness settings (keep `.claude/commands/`, skip local settings)
.claude/settings.local.json
# Transient git worktrees used by the local agent harness (never committed)
.claude/worktrees/
# Transient scheduled-task lock file emitted by the harness runtime
.claude/scheduled_tasks.lock

# TypeScript incremental build info
*.tsbuildinfo

# Local run output (Gradle, pnpm, background tasks)
.logs/

# JVM crash dumps and snapshots (OpenJ9 / HotSpot)
core.*.dmp
javacore.*.txt
Snap.*.trc
hs_err_pid*.log

# Kotlin build cache
.kotlin/
