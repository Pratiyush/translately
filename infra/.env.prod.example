# Translately — production environment variables.
# Copy to `.env.prod` at repo root and edit. NEVER commit the real file.
#
# Generate strong random values:
#   openssl rand -base64 32    # for JWT_SECRET and CRYPTO_MASTER_KEY
#   openssl rand -hex 20       # for POSTGRES_PASSWORD / MINIO_ROOT_PASSWORD

# Release to deploy (defaults to "latest" — pin a tag in production)
TRANSLATELY_VERSION=0.0.1

# ---- Postgres ----
POSTGRES_USER=translately
POSTGRES_DB=translately
POSTGRES_PASSWORD=change-me-long-random

# ---- MinIO / S3-compatible object storage ----
MINIO_ROOT_USER=translately
MINIO_ROOT_PASSWORD=change-me-long-random
S3_REGION=us-east-1

# ---- SMTP ----
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=no-reply@example.com
SMTP_PASSWORD=change-me
MAIL_FROM=no-reply@example.com

# ---- Secrets ----
# 32-byte base64, used to sign Smallrye JWTs
JWT_SECRET=change-me-base64-32-bytes
# 32-byte base64, used as KEK for envelope-encrypting per-project AI API keys
CRYPTO_MASTER_KEY=change-me-base64-32-bytes
